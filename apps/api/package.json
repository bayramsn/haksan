{
  "name": "@haksan/api",
  "version": "0.1.0",
  "private": true,
  "description": "CNC ERP/CRM backend — NestJS + Drizzle + Fastify",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:seed:lookups": "tsx src/db/seed/lookups.ts",
    "db:seed:demo": "tsx src/db/seed/demo.ts",
    "db:import:haksancnc": "tsx src/db/seed/haksancnc.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.687.0",
    "@aws-sdk/s3-request-presigner": "3.687.0",
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "9.0.1",
    "@fastify/helmet": "11.1.1",
    "@fastify/rate-limit": "9.1.0",
    "@haksan/shared": "*",
    "@nestjs/common": "10.4.7",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.7",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-fastify": "10.4.7",
    "@nestjs/throttler": "6.2.1",
    "argon2": "0.41.1",
    "exceljs": "4.4.0",
    "file-type": "16.5.4",
    "nanoid": "5.0.9",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.7",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.7",
    "@swc/core": "1.9.3",
    "@types/node": "22.9.0",
    "@types/pg": "8.11.10",
    "@types/supertest": "6.0.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "unplugin-swc": "1.5.1",
    "vitest": "2.1.5"
  }
}
