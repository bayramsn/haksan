# Backend env (NestJS + Drizzle)
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_PROVIDER=postgres
DATABASE_URL=postgres://haksan:haksan_dev_pwd@localhost:5432/haksan
DATABASE_POOL_MAX=10

# CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Cookie / session
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# JWT
JWT_ACCESS_SECRET=change-me-access-development-only-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-development-only-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Auth lockout
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Rate limit (per minute)
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_LOGIN=5

# Storage
S3_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_PREFIX=erp
S3_FORCE_PATH_STYLE=true

# Supabase (only used when S3_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upload constraints
MAX_UPLOAD_SIZE_MB=25
SIGNED_URL_EXPIRE_SECONDS=300

# Password reset
RESET_TOKEN_TTL_MINUTES=60

# Mail (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@haksan.local
